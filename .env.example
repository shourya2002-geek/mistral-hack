# ============================================================================
# EditOS — Environment Configuration
# ============================================================================
# Copy to .env and fill in your values.

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- Mistral AI ---
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_ORCHESTRATOR_MODEL=mistral-large-latest
MISTRAL_INTENT_MODEL=ministral-8b-latest
MISTRAL_STRATEGY_MODEL=ministral-8b-latest
MISTRAL_COLLAB_MODEL=ministral-8b-latest
MISTRAL_PUBLISH_MODEL=ministral-3b-latest
MISTRAL_VOICE_MODEL=mistral-large-latest

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Storage ---
UPLOAD_DIR=./storage/uploads
TEMP_DIR=./storage/temp
OUTPUT_DIR=./storage/output

# --- Workers ---
RENDER_CONCURRENCY=2
ANALYSIS_CONCURRENCY=4

# --- Voice ---
VOICE_MAX_SESSION_DURATION_MS=1800000
VOICE_SILENCE_THRESHOLD_MS=500

# --- CORS ---
CORS_ORIGIN=*
